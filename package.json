{
  "name": "effect-typed-id",
  "version": "0.1.0",
  "description": "Effect TypeScript implementation of the TypeID spec",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/just-be-dev/effect-typed-id.git"
  },
  "bugs": {
    "url": "https://github.com/just-be-dev/effect-typed-id/issues"
  },
  "homepage": "https://github.com/just-be-dev/effect-typed-id#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.90",
    "typescript": "^7.0.1-rc"
  },
  "scripts": {
    "build": "rm -rf dist && tsgo && rm -f dist/*.test.*",
    "check": "bun run typecheck && bun run test",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "prepare": "bun run effect-tsgo patch"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/tsgo": "^0.14.6",
    "@types/bun": "latest",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "effect-solutions": "^0.5.3",
    "typescript": "7.0.1-rc"
  },
  "trustedDependencies": [
    "@typescript/native-preview"
  ]
}
